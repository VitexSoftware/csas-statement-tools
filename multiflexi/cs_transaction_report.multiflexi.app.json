{
  "$schema": "https://raw.githubusercontent.com/VitexSoftware/php-vitexsoftware-multiflexi-core/refs/heads/main/schema/application.json",
  "schemaVersion": "3.2.1",
  "uuid": "d82ef26e-2bfc-4171-ad92-4eae643a5249",
  "name": {
    "en": "ČSas transaction report",
    "cs": "ČSas transakční report"
  },
  "description": {
    "en": "CSas transaction report",
    "cs": "CSas transakční report"
  },
  "tags": [
    "Bank",
    "Csas",
    "Transactions",
    "Check",
    "Json",
    "Report"
  ],
  "homepage": "https://github.com/VitexSoftware/csas-statement-tools",
  "executable": "csas-transaction-report",
  "environment": {
    "CSAS_API_KEY": {
      "type": "string",
      "description": {
        "en": "API key for CSAS",
        "cs": "API klíč pro CSAS"
      },
      "required": true,
      "category": "Other"
    },
    "CSAS_ACCESS_TOKEN": {
      "type": "string",
      "description": {
        "en": "Access token for CSAS",
        "cs": "Přístupový token pro CSAS"
      },
      "required": true,
      "category": "Security"
    },
    "CSAS_ACCOUNT_IBAN": {
      "type": "string",
      "description": {
        "en": "IBAN of the CSAS account",
        "cs": "IBAN účtu CSAS"
      },
      "required": false,
      "category": "Other"
    },
    "CSAS_ACCOUNT_UUID": {
      "type": "string",
      "description": {
        "en": "UUID of the CSAS account",
        "cs": "UUID účtu CSAS"
      },
      "required": false,
      "category": "Other"
    },
    "CSAS_SANDBOX_MODE": {
      "type": "bool",
      "description": {
        "en": "Enable sandbox mode for CSAS",
        "cs": "Povolit sandbox režim pro CSAS"
      },
      "defval": false,
      "required": false,
      "category": "Other"
    },
    "CSAS_API_DEBUG": {
      "type": "bool",
      "description": {
        "en": "Enable API debug mode",
        "cs": "Povolit režim ladění API"
      },
      "defval": false,
      "required": false,
      "category": "Behavior"
    },
    "APP_DEBUG": {
      "type": "bool",
      "description": {
        "en": "Enable application debug mode",
        "cs": "Povolit režim ladění aplikace"
      },
      "defval": false,
      "required": false,
      "category": "Behavior"
    },
    "ACCOUNT_NUMBER": {
      "type": "string",
      "description": {
        "en": "Bank Account Number",
        "cs": "Číslo bankovního účtu"
      },
      "defval": "",
      "required": false,
      "category": "Other"
    },
    "ACCOUNT_CURRENCY": {
      "type": "string",
      "description": {
        "en": "for multicurrency accounts please specify one",
        "cs": "Pro více měnové účty prosím specifikujte jednu"

      },
      "defval": "CZK",
      "required": false,
      "category": "Other"
    },
    "REPORT_SCOPE": {
      "type": "string",
      "description": {
        "en": "Time scope of transactions downloaded",
        "cs": "Časový rozsah stažených transakcí"
      },
      "defval": "last_month",
      "required": false,
      "category": "Other"
    },
    "STATEMENT_FORMAT": {
      "type": "set",
      "description": {
        "en": "pdf or xml",
        "cs": "pdf nebo xml"
      },
      "defval": "xml",
      "options": {
        "pdf": "PDF",
        "xml": "XML"
      },
      "required": false,
      "category": "Other"
    },
    "RESULT_FILE": {
      "type": "string",
      "description": {
        "en": "write output json data to",
        "cs": "zapsat výstupní json data do"
      },
      "defval": "transaction_report_{ACCOUNT_NUMBER}.json",
      "required": false,
      "category": "Other"
    },
    "ZABBIX_KEY": {
      "type": "string",
      "description": {
        "en": "Default name for Zabbix Item key name",
        "cs": "Výchozí název pro klíč položky Zabbix"
      },
      "defval": "Raiff-Balance-{ACCOUNT_NUMBER}",
      "required": false,
      "category": "Other"
    },
    "EASE_LOGGER": {
      "type": "string",
      "description": {
        "en": "write log messages using",
        "cs": "zapisovat logovací zprávy pomocí"
      },
      "defval": "console|syslog",
      "required": false,
      "category": "Behavior"
    }
  },
  "artifacts": [
    {
      "name": "Transaction report",
      "type": "file",
      "description": {
        "en": "Generated bank statements",
        "cs": "Generované bankovní výpisy"
      },
      "path": "^transaction_report_[A-Za-z0-9]+\\.json$"
    }
  ]
}
