{
  "$schema": "https://raw.githubusercontent.com/VitexSoftware/php-vitexsoftware-multiflexi-core/refs/heads/main/schema/application.json",
  "schemaVersion": "3.2.1",
  "uuid": "589dfb07-eb27-450e-95c6-3e8edfd1e7d2",
  "name": {
    "en": "ČSas statement downloader",
    "cs": "ČSas statement downloader"
  },
  "description": {
    "en": "Download Csas statements in given format",
    "cs": "Stáhnout výpisy ČSas v zadaném formátu"
  },
  "tags": [
    "Csas",
    "Statements",
    "Downloader"
  ],
  "homepage": "https://github.com/VitexSoftware/csas-statement-tools",
  "executable": "csas-statement-downloader",
  "environment": {
    "CSAS_API_KEY": {
      "type": "string",
      "description": {
        "en": "API key for CSAS",
        "cs": "API klíč pro CSAS"
      },
      "required": true,
      "category": "Other"
    },
    "CSAS_ACCESS_TOKEN": {
      "type": "string",
      "description": {
        "en": "Access token for CSAS",
        "cs": "Přístupový token pro CSAS"
      },
      "required": true,
      "category": "Security"
    },
    "CSAS_ACCOUNT_IBAN": {
      "type": "string",
      "description": {
        "en": "IBAN of the CSAS account",
        "cs": "IBAN účtu CSAS"
      },
      "required": true,
      "category": "Other"
    },
    "CSAS_ACCOUNT_UUID": {
      "type": "string",
      "description": {
        "en": "UUID of the CSAS account",
        "cs": "UUID účtu CSAS"
      },
      "required": true,
      "category": "Other"
    },
    "CSAS_SANDBOX_MODE": {
      "type": "bool",
      "description": {
        "en": "Enable sandbox mode for CSAS",
        "cs": "Povolit režim sandbox pro CSAS"
      },
      "defval": false,
      "required": false,
      "category": "Other"
    },
    "CSAS_API_DEBUG": {
      "type": "bool",
      "description": {
        "en": "Enable API debug mode",
        "cs": "Povolit režim ladění API"
      },
      "defval": false,
      "required": false,
      "category": "Behavior"
    },
    "APP_DEBUG": {
      "type": "bool",
      "description": {
        "en": "Enable application debug mode",
        "cs": "Povolit režim ladění aplikace"
      },
      "defval": false,
      "required": false,
      "category": "Behavior"
    },
    "IMPORT_SCOPE": {
      "type": "string",
      "description": {
        "en": "Time scope of transactions downloaded",
        "cs": "Časový rozsah stažených transakcí"
      },
      "defval": "auto",
      "required": false,
      "category": "Other"
    },
    "STATEMENTS_DIR": {
      "type": "string",
      "description": {
        "en": "Directory to save statements",
        "cs": "Adresář pro uložení výpisů"
      },
      "defval": ".",
      "required": false,
      "category": "Other"
    },
    "STATEMENT_FORMAT": {
      "type": "set",
      "description": {
        "en": "pdf or xml",
        "cs": "pdf nebo xml"
      },
      "defval": "pdf",
      "options": {
        "pdf": "PDF",
        "xml": "XML",
        "xml-data": "XML Data",
        "abo-standard": "ABO Standard",
        "abo-internal": "ABO Internal",
        "abo-standard-extended": "ABO Standard Extended",
        "abo-internal-extended": "ABO Internal Extended",
        "csv-comma": "CSV Comma",
        "csv-semicolon": "CSV Semicolon",
        "mt940": "MT940"
      },
      "required": false,
      "category": "Other"
    },
    "ACCOUNT_CURRENCY": {
      "type": "string",
      "description": {
        "en": "for multicurrency accounts please specify one",
        "cs": "Pro více měnové účty prosím specifikujte jednu"
      },
      "defval": "CZK",
      "required": false,
      "category": "Other"
    },
    "RESULT_FILE": {
      "type": "string",
      "description": {
        "en": "write output json data to",
        "cs": "zapsat výstupní json data do"
      },
      "defval": "csas_statement_downloader.json",
      "required": false,
      "category": "Other"
    },
    "EASE_LOGGER": {
      "type": "string",
      "description": {
        "en": "write log messages using",
        "cs": "zapisovat logovací zprávy pomocí"
      },
      "defval": "console|syslog",
      "required": false,
      "category": "Behavior"
    },
    "CSAS_GENERATE_EMPTY_STATEMENTS": {
      "type": "bool",
      "description": {
        "en": "Generate mock statements when no transactions are available for the period",
        "cs": "Generovat falešné výpisy, pokud nejsou k dispozici žádné transakce za období"
      },
      "defval": false,
      "required": false,
      "category": "Other"
    }
  },
  "artifacts": [
    {
      "name": "Output JSON report",
      "type": "file",
      "path": "csas_statement_downloader.json",
      "description": {
        "en": "Output JSON data file",
        "cs": "Výstupní JSON datový soubor"
      }
    },
    {
      "name": "Statements Directory",
      "type": "directory",
      "path": ".",
      "description": {
        "en": "Directory to save statements",
        "cs": "Adresář pro uložení výpisů"
      }
    }
  ],
  "exitCodes": {
    "0": {
      "description": {
        "en": "Success",
        "cs": "Úspěch"
      },
      "severity": "success",
      "retry": false
    },
    "1": {
      "description": {
        "en": "General error",
        "cs": "Obecná chyba"
      },
      "severity": "error",
      "retry": true
    },
    "5": {
      "description": {
        "en": "Application-specific error code 5",
        "cs": "Aplikační chybový kód 5"
      },
      "severity": "error",
      "retry": true
    }
  }
}
