{
  "$schema": "https://raw.githubusercontent.com/VitexSoftware/php-vitexsoftware-multiflexi-core/refs/heads/main/schema/application.json",
  "schemaVersion": "3.2.1",
  "uuid": "e7df927a-a30e-40fe-ac3e-d4e547be8f95",
  "name": {
    "en": "ČSas Balance",
    "cs": "ČSas zůstatek"
  },
  "description": {
    "en": "CSas Balance check",
    "cs": "Kontrola zůstatku na účtu CSas"
  },
  "tags": [
    "Csas",
    "Balance",
    "Check",
    "Json"
  ],
  "homepage": "https://github.com/VitexSoftware/csas-statement-tools",
  "executable": "csas-balance",
  "environment": {
    "CSAS_API_KEY": {
      "type": "string",
      "description": {
        "en": "API key for CSAS",
        "cs": "API klíč pro CSAS"
      },
      "required": true,
      "category": "Other"
    },
    "CSAS_ACCESS_TOKEN": {
      "type": "string",
      "description": {
        "en": "Access token for CSAS",
        "cs": "Přístupový token pro CSAS"
      },
      "required": true,
      "category": "Security"
    },
    "CSAS_ACCOUNT_IBAN": {
      "type": "string",
      "description": {
        "en": "IBAN of the CSAS account",
        "cs": "IBAN účtu CSAS"
      },
      "required": true,
      "category": "Other"
    },
    "CSAS_ACCOUNT_UUID": {
      "type": "string",
      "description": {
        "en": "UUID of the CSAS account",
        "cs": "UUID účtu CSAS"
      },
      "required": false,
      "category": "Other"
    },
    "CSAS_SANDBOX_MODE": {
      "type": "bool",
      "description": {
        "en": "Enable sandbox mode for CSAS",
        "cs": "Povolit režim sandbox pro CSAS"
      },
      "defval": false,
      "required": false,
      "category": "Other"
    },
    "CSAS_API_DEBUG": {
      "type": "bool",
      "description": {
        "en": "Enable API debug mode",
        "cs": "Povolit režim ladění API"
      },
      "defval": false,
      "required": false,
      "category": "Behavior"
    },
    "APP_DEBUG": {
      "type": "bool",
      "description": {
        "en": "Enable application debug mode",
        "cs": "Povolit režim ladění aplikace"
      },
      "defval": false,
      "required": false,
      "category": "Behavior"
    },
    "RESULT_FILE": {
      "type": "string",
      "description": {
        "en": "write output json data to",
        "cs": "Zapsat výstupní JSON data do souboru"
      },
      "defval": "csas_balance.json",
      "required": false,
      "category": "Other"
    },
    "EASE_LOGGER": {
      "type": "string",
      "description": {
        "en": "write log messages using",
        "cs": "Zapisovat logovací zprávy pomocí"
      },
      "defval": "console|syslog",
      "required": false,
      "category": "Behavior"
    }
  },
  "artifacts": [
    {
      "name": "Result JSON report",
      "path": "csas_balance.json",
      "type": "file",
      "description": {
        "en": "Output file containing the balance data in JSON format",
        "cs": "Výstupní soubor obsahující data o zůstatku ve formátu JSON"
      }
    }
  ]
}
